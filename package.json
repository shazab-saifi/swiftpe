{
  "name": "swiftpe",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "backend:dev": "bun run --cwd apps/backend dev",
    "backend:build": "bun run --cwd apps/backend build",
    "backend:start": "bun run --cwd apps/backend start",
    "frontend:dev": "bun run --cwd apps/frontend dev",
    "frontend:build": "bun run --cwd apps/frontend build",
    "frontend:start": "bun --cwd apps/frontend .next/standalone/server.js"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
